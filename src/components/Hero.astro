---
---

<section id="inicio" class="min-h-screen flex flex-col items-center justify-center text-center pt-16 px-6">
  <div class="max-w-4xl mx-auto w-full">

    <!-- Badge -->
    <div class="flex justify-center mb-10 reveal">
      <span class="badge">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400" style="animation: pulse 2s ease-in-out infinite;"></span>
        Disponible para trabajar
      </span>
    </div>

    <!-- Name: centered, with proper spacing to avoid accent clipping -->
    <div class="reveal" style="transition-delay: 80ms;">
      <div
        style="font-size: clamp(4.5rem, 14vw, 11rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1; color: #fafafa; text-transform: uppercase;"
      >
        Alex
      </div>
      <div
        style="font-size: clamp(4.5rem, 14vw, 11rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.05; color: #f59e0b; text-transform: uppercase; padding-top: 0.06em;"
      >
        Pérez
      </div>
    </div>

    <!-- Subtitle + typewriter -->
    <div class="mt-10 reveal" style="transition-delay: 160ms;">
      <p class="text-zinc-400 text-lg mb-3 leading-relaxed">
        Desarrollador <strong class="text-zinc-100 font-semibold">Backend & Mobile</strong> ·
        Premio a la Excelencia Académica en DAM
      </p>
      <div class="text-sm text-zinc-600 font-mono mb-10 flex items-center justify-center gap-1">
        I am a
        <span id="typewriter" class="text-amber-400 font-semibold ml-1 min-w-[1ch]"></span>
        <span class="tw-cursor text-amber-400">|</span>
      </div>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="#contacto" class="btn-primary">
          Contactar <i class="fas fa-arrow-right text-[10px]"></i>
        </a>
        <a href="https://github.com/alexP-codeLab" target="_blank" rel="noopener noreferrer" class="btn-outline">
          <i class="fab fa-github"></i> GitHub
        </a>
        <a href="https://www.linkedin.com/in/alex-perez-salazar-5b2b14229" target="_blank" rel="noopener noreferrer" class="btn-outline">
          <i class="fab fa-linkedin"></i> LinkedIn
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="mt-20 flex flex-col items-center gap-2 text-zinc-700 reveal" style="transition-delay: 260ms;">
      <span class="text-[10px] font-mono uppercase tracking-[0.25em]">Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-zinc-700 to-transparent"></div>
    </div>

  </div>
</section>

<script>
  const words = ['Backend Developer', 'Mobile Developer', 'Cloud Engineer', 'Problem Solver'];
  let wi = 0, ci = 0, del = false;
  function tick() {
    const el = document.getElementById('typewriter');
    if (!el) return;
    const w = words[wi];
    if (!del) {
      el.textContent = w.slice(0, ++ci);
      if (ci === w.length) { del = true; setTimeout(tick, 2200); return; }
    } else {
      el.textContent = w.slice(0, --ci);
      if (ci === 0) { del = false; wi = (wi + 1) % words.length; }
    }
    setTimeout(tick, del ? 50 : 95);
  }
  tick();
</script>
