---
const projects = [
  {
    number:   '01',
    icon:     'fas fa-play-circle',
    badge:    'TFG',
    title:    'Freelix',
    subtitle: 'App de Streaming Multiplataforma',
    desc:     'Aplicación móvil multiplataforma de streaming de vídeo bajo arquitectura Cliente-Servidor. Frontend en Flutter, backend RESTful con Spring Boot securizado con Spring Security, persistencia en MySQL y despliegue en Azure App Service.',
    tech:     ['Flutter', 'Spring Boot', 'Spring Security', 'MySQL', 'Azure App Service', 'Firebase Auth/Storage', 'TMDB API'],
  },
  {
    number:   '02',
    icon:     'fas fa-database',
    badge:    'Data Engineering',
    title:    'La Liga XML Pipeline',
    subtitle: 'Pipeline de Procesamiento de Datos',
    desc:     'Diseño y desarrollo de un pipeline automatizado para la extracción y procesamiento de datos masivos mediante parseo y manipulación avanzada de archivos XML, garantizando la integridad de la información deportiva.',
    tech:     ['XML', 'Data Engineering', 'ETL', 'Java'],
  },
];
---

<section id="proyectos" class="py-24">
  <div class="mx-auto px-6 max-w-7xl">

    <div class="mb-14 reveal">
      <p class="section-label"><span class="amber-line"></span>Proyectos</p>
    </div>

    <!-- Full-width cards, one per row — very different from two-column grid -->
    <div class="flex flex-col gap-5 reveal">
      {projects.map((p, i) => (
        <div
          class="card p-8 grid sm:grid-cols-[5rem,1fr] gap-8 items-start group hover:border-amber-500/30 transition-colors"
          style={`transition-delay: ${i * 100}ms`}
        >
          <!-- Big number -->
          <div class="text-center">
            <span class="text-6xl font-black text-zinc-800 group-hover:text-amber-500/20 transition-colors leading-none select-none block">
              {p.number}
            </span>
            <div class="w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 mx-auto mt-3 group-hover:bg-amber-500/20 transition-colors">
              <i class={`${p.icon} text-sm`}></i>
            </div>
          </div>

          <!-- Content -->
          <div>
            <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
              <div>
                <h3 class="text-2xl font-extrabold tracking-tight text-zinc-100 group-hover:text-amber-400 transition-colors">
                  {p.title}
                </h3>
                <p class="text-sm font-semibold text-amber-500/70 mt-0.5">{p.subtitle}</p>
              </div>
              <span class="badge text-[11px]">{p.badge}</span>
            </div>

            <p class="text-sm text-zinc-400 leading-relaxed mb-5">{p.desc}</p>

            <div class="flex flex-wrap gap-2 pt-4 border-t border-zinc-800/60">
              {p.tech.map(t => <span class="tech-tag">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
