---
---

<section id="contacto" class="py-24">
  <div class="mx-auto px-6 max-w-7xl">

    <div class="mb-12 reveal">
      <p class="section-label"><span class="amber-line"></span>Contacto</p>
      <h2 class="section-title">Hablemos</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5 reveal">

      <!-- ── Info ──────────────────────────────────────── -->
      <div class="card p-7 flex flex-col justify-between gap-8 hover:border-amber-500/30 transition-colors">
        <div>
          <h3 class="text-xl font-extrabold tracking-tight mb-2 text-zinc-100">¿Tienes un proyecto?</h3>
          <p class="text-sm text-zinc-500 leading-relaxed">
            Estoy listo para nuevos desafíos. Escríbeme y hablamos.
          </p>
        </div>

        <div class="flex flex-col gap-3">
          <a
            href="mailto:alexps130803@gmail.com"
            class="flex items-center gap-3 group p-3 rounded-lg hover:bg-zinc-800/60 transition-colors"
          >
            <div class="w-9 h-9 rounded-lg bg-zinc-800 border border-zinc-700 group-hover:border-amber-500/40 flex items-center justify-center flex-shrink-0 transition-colors">
              <i class="fas fa-envelope text-xs text-zinc-400 group-hover:text-amber-400 transition-colors"></i>
            </div>
            <div>
              <p class="text-[11px] text-zinc-600 uppercase tracking-wider">Email</p>
              <p class="text-sm font-medium text-zinc-300 group-hover:text-amber-400 transition-colors">
                alexps130803@gmail.com
              </p>
            </div>
          </a>

          <a
            href="tel:+34661470738"
            class="flex items-center gap-3 group p-3 rounded-lg hover:bg-zinc-800/60 transition-colors"
          >
            <div class="w-9 h-9 rounded-lg bg-zinc-800 border border-zinc-700 group-hover:border-amber-500/40 flex items-center justify-center flex-shrink-0 transition-colors">
              <i class="fas fa-phone text-xs text-zinc-400 group-hover:text-amber-400 transition-colors"></i>
            </div>
            <div>
              <p class="text-[11px] text-zinc-600 uppercase tracking-wider">Teléfono</p>
              <p class="text-sm font-medium text-zinc-300 group-hover:text-amber-400 transition-colors">
                +34 661 47 07 38
              </p>
            </div>
          </a>
        </div>

        <!-- Social -->
        <div class="flex gap-3 pt-2 border-t border-zinc-800">
          <a
            href="https://www.linkedin.com/in/alex-perez-salazar-5b2b14229"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center gap-2 py-2.5 rounded-lg border border-zinc-700 text-zinc-400 text-sm font-medium hover:border-amber-500/40 hover:text-amber-400 hover:bg-amber-500/5 transition-all"
          >
            <i class="fab fa-linkedin"></i> LinkedIn
          </a>
          <a
            href="https://github.com/alexP-codeLab"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center gap-2 py-2.5 rounded-lg border border-zinc-700 text-zinc-400 text-sm font-medium hover:border-amber-500/40 hover:text-amber-400 hover:bg-amber-500/5 transition-all"
          >
            <i class="fab fa-github"></i> GitHub
          </a>
        </div>
      </div>

      <!-- ── Form ───────────────────────────────────────── -->
      <div class="card p-7 hover:border-zinc-700 transition-colors" style="transition-delay: 80ms;">
        <form action="https://formspree.io/f/mrboyrjj" method="POST" class="flex flex-col gap-4 h-full">
          <input
            type="text" name="name" placeholder="Nombre" required
            class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3
                   text-sm text-zinc-100 placeholder-zinc-600
                   focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/20
                   transition-colors"
          />
          <input
            type="email" name="email" placeholder="Email" required
            class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3
                   text-sm text-zinc-100 placeholder-zinc-600
                   focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/20
                   transition-colors"
          />
          <textarea
            name="message" rows="6" placeholder="Tu mensaje..." required
            class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3
                   text-sm text-zinc-100 placeholder-zinc-600
                   focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/20
                   transition-colors resize-none flex-1"
          ></textarea>
          <button type="submit" class="btn-primary w-full justify-center mt-auto">
            Enviar Mensaje <i class="fas fa-paper-plane text-[10px]"></i>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
