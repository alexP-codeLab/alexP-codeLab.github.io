---
---

<section id="contacto" class="py-24">
  <div class="container mx-auto px-6 max-w-6xl">
    <h2 class="section-title reveal">
      <span class="gradient-text">Hablemos</span>
    </h2>

    <div class="glass-card overflow-hidden reveal">
      <div class="grid md:grid-cols-2">

        <!-- ── Left: info ──────────────────────────────── -->
        <div
          class="p-8 md:p-10 border-b md:border-b-0 md:border-r border-zinc-800"
          style="background: linear-gradient(135deg, rgba(99,102,241,0.08) 0%, transparent 60%);"
        >
          <h3 class="text-xl font-bold mb-2">¿Tienes un proyecto?</h3>
          <p class="text-zinc-400 text-sm mb-8 leading-relaxed">
            Estoy listo para nuevos desafíos. Escríbeme y hablamos.
          </p>

          <div class="space-y-3 mb-8">
            <a
              href="mailto:alexps130803@gmail.com"
              class="flex items-center gap-3 text-sm text-zinc-300 hover:text-indigo-400 transition-colors group"
            >
              <div
                class="w-9 h-9 rounded-lg bg-zinc-800 border border-zinc-700
                       group-hover:bg-indigo-500/10 group-hover:border-indigo-500/30
                       flex items-center justify-center transition-colors flex-shrink-0"
              >
                <i class="fas fa-envelope text-xs text-zinc-400 group-hover:text-indigo-400 transition-colors"></i>
              </div>
              alexps130803@gmail.com
            </a>
            <a
              href="tel:+34661470738"
              class="flex items-center gap-3 text-sm text-zinc-300 hover:text-indigo-400 transition-colors group"
            >
              <div
                class="w-9 h-9 rounded-lg bg-zinc-800 border border-zinc-700
                       group-hover:bg-indigo-500/10 group-hover:border-indigo-500/30
                       flex items-center justify-center transition-colors flex-shrink-0"
              >
                <i class="fas fa-phone text-xs text-zinc-400 group-hover:text-indigo-400 transition-colors"></i>
              </div>
              +34 661 47 07 38
            </a>
          </div>

          <!-- Social -->
          <div class="flex gap-3">
            <a
              href="https://www.linkedin.com/in/alex-perez-salazar-5b2b14229"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-lg bg-zinc-800 border border-zinc-700
                     hover:bg-indigo-500/10 hover:border-indigo-500/30
                     flex items-center justify-center
                     text-zinc-400 hover:text-indigo-400 transition-all"
              aria-label="LinkedIn"
            >
              <i class="fab fa-linkedin text-sm"></i>
            </a>
            <a
              href="https://github.com/alexP-codeLab"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-lg bg-zinc-800 border border-zinc-700
                     hover:bg-indigo-500/10 hover:border-indigo-500/30
                     flex items-center justify-center
                     text-zinc-400 hover:text-indigo-400 transition-all"
              aria-label="GitHub"
            >
              <i class="fab fa-github text-sm"></i>
            </a>
          </div>
        </div>

        <!-- ── Right: form ─────────────────────────────── -->
        <div class="p-8 md:p-10">
          <form
            action="https://formspree.io/f/mrboyrjj"
            method="POST"
            class="space-y-4"
          >
            <input
              type="text"
              name="name"
              placeholder="Nombre"
              required
              class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-2.5
                     text-sm text-zinc-100 placeholder-zinc-600
                     focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/30
                     transition-colors"
            />
            <input
              type="email"
              name="email"
              placeholder="Email"
              required
              class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-2.5
                     text-sm text-zinc-100 placeholder-zinc-600
                     focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/30
                     transition-colors"
            />
            <textarea
              name="message"
              rows="5"
              placeholder="Tu mensaje..."
              required
              class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-2.5
                     text-sm text-zinc-100 placeholder-zinc-600
                     focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/30
                     transition-colors resize-none"
            ></textarea>
            <button type="submit" class="btn-primary w-full justify-center">
              Enviar Mensaje <i class="fas fa-paper-plane text-[10px]"></i>
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>
