---
const skills = [
  { icon: 'fas fa-server',     title: 'Backend',        tags: ['Java', 'Spring Boot', 'Hibernate', 'C#', 'PHP', 'Python'] },
  { icon: 'fas fa-mobile-alt', title: 'Mobile & Front', tags: ['Dart (Flutter)', 'JavaScript', 'HTML', 'CSS'] },
  { icon: 'fas fa-brain',      title: 'IA & Data',      tags: ['OpenAI API', 'PaddleOCR'] },
  { icon: 'fas fa-cloud',      title: 'Cloud & DevOps', tags: ['Azure Service Bus', 'Azure Container Apps', 'Git', 'Postman'] },
  { icon: 'fas fa-database',   title: 'Bases de Datos', tags: ['MongoDB', 'MySQL', 'PostgreSQL', 'Firebase'] },
  { icon: 'fab fa-wordpress',  title: 'CMS',            tags: ['WordPress'] },
  { icon: 'fas fa-language',   title: 'Idiomas',        tags: ['Español (Nativo)', 'Gallego (Nativo)', 'Inglés (C1)', 'Italiano (B1/B2)'] },
];
---

<section id="competencias" class="py-24">
  <div class="mx-auto px-6 max-w-7xl">

    <div class="mb-14 reveal">
      <p class="section-label"><span class="amber-line"></span>Stack Tecnológico</p>
    </div>

    <!-- Horizontal rows — completely different from grid of cards -->
    <div class="divide-y divide-zinc-800/60 reveal">
      {skills.map((s, i) => (
        <div
          class="group py-5 flex flex-col sm:flex-row sm:items-center gap-4 hover:bg-zinc-900/40 transition-colors px-4 -mx-4 rounded-xl"
          style={`transition-delay: ${i * 40}ms`}
        >
          <!-- Label column -->
          <div class="flex items-center gap-3 w-44 flex-shrink-0">
            <i class={`${s.icon} text-amber-500/70 group-hover:text-amber-500 transition-colors w-4 text-sm`}></i>
            <span class="text-sm font-semibold text-zinc-500 group-hover:text-zinc-300 transition-colors">{s.title}</span>
          </div>
          <!-- Tags inline -->
          <div class="flex flex-wrap gap-2">
            {s.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
